{
  "name": "clinic-appointments",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "pnpm -r build",
    "predev": "pnpm --filter @clinic/shared build",
    "dev": "pnpm -r --parallel --if-present dev"
  },
  "pnpm": {
    "supportedArchitectures": {
      "os": ["current", "linux"],
      "cpu": ["current", "x64", "arm64"]
    }
  }
}
