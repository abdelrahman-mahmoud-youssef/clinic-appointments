generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Mirrors @clinic/shared Role exactly.
enum Role {
  ADMIN
  RECEPTIONIST
  DOCTOR
}

// Mirrors @clinic/shared AppointmentStatus exactly.
enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Clinic {
  id        String   @id @default(uuid())
  name      String
  timezone  String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  users          User[]
  doctors        Doctor[]
  patients       Patient[]
  appointments   Appointment[]
  availabilities DoctorAvailability[]
}

model User {
  id             String   @id @default(uuid())
  clinicId       String
  email          String   @unique
  hashedPassword String
  role           Role
  doctorId       String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinic Clinic  @relation(fields: [clinicId], references: [id])
  doctor Doctor? @relation(fields: [doctorId], references: [id])

  @@index([clinicId])
}

model Doctor {
  id        String   @id @default(uuid())
  clinicId  String
  name      String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  clinic         Clinic               @relation(fields: [clinicId], references: [id])
  user           User?
  appointments   Appointment[]
  availabilities DoctorAvailability[]

  @@index([clinicId])
}

// Weekly recurring working hours. A doctor can have multiple rows per weekday
// (split shifts, e.g. 09:00-12:00 and 13:00-17:00).
model DoctorAvailability {
  id        String   @id @default(uuid())
  clinicId  String
  doctorId  String
  weekday   Int
  startTime String
  endTime   String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  clinic Clinic @relation(fields: [clinicId], references: [id])
  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@index([clinicId, doctorId, weekday])
}

model Patient {
  id        String   @id @default(uuid())
  clinicId  String
  name      String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  clinic       Clinic        @relation(fields: [clinicId], references: [id])
  appointments Appointment[]

  @@index([clinicId])
}

model Appointment {
  id        String            @id @default(uuid())
  clinicId  String
  patientId String
  doctorId  String
  startsAt  DateTime          @db.Timestamptz(3)
  endsAt    DateTime          @db.Timestamptz(3)
  status    AppointmentStatus @default(SCHEDULED)
  reason    String?
  notes     String?
  createdBy String
  updatedBy String
  createdAt DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt DateTime          @updatedAt @db.Timestamptz(3)

  clinic  Clinic  @relation(fields: [clinicId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])
  doctor  Doctor  @relation(fields: [doctorId], references: [id])

  @@index([clinicId, doctorId, startsAt])
  @@index([clinicId, startsAt])
}
